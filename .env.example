# BirdsEye paths — copy to `.env` and edit for your machine.
#   cp .env.example .env
# A real OS environment variable of the same name overrides any line here.
# Point at a different file with $BIRDSEYE_ENV.

# REQUIRED: your Intern-Project checkout (BirdsEye reads raw /mnt data through its pipeline).
INTERN_PROJECT_DIR=/path/to/Intern-Project

# Train/val/test day assignment used by the runner and the learners.
MANIFEST_PATH=/path/to/manifest.json

# Optional: override the raw data directory (default: config.get_data_dir(index)).
# DATA_DIR=/mnt/INTERNAL_DATA/INTERN_DATA/OPRA_DATA_1SEC/0DTE/SPY

# Optional: where run logs are written (default: <repo>/logs).
# LOG_DIR=/path/to/logs
